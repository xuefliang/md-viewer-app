{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MD Viewer",
  "version": "0.4.0",
  "identifier": "com.tongzhao.md-viewer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MD Viewer",
        "width": 1200,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI5QTM2RENCQjhEMDk3ClJXU1gwTGpMYmFPNUFLM3BoMGgzc1I1Rk1kbTM2RTdFczVhUzJwZCtKek1LcTRWd3RodTJ5bHBsCg==",
      "endpoints": [
        "https://github.com/Tongzhao9417/md-viewer-app/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
